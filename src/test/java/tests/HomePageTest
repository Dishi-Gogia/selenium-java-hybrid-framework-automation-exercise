package tests;

import org.apache.logging.log4j.Logger;
import org.testng.Assert;
import org.testng.annotations.Test;

import base.BaseTest;
import factory.DriverFactory;
import pages.HomePage;
import utilities.LoggerUtils;

public class HomePageTest extends BaseTest {

    private static final Logger logger =
            LoggerUtils.getLogger(HomePageTest.class);

    /**
     * Validates that the application
     * home page is loaded successfully.
     */
    @Test(groups = {"regression"},priority=1)
    public void verifyHomePageTitle() {

        logger.info("===== Starting Home Page Title Validation Test =====");

        HomePage homePage =new HomePage( DriverFactory.getDriver());

        String title = homePage.getHomePageTitle();

        logger.info("Home Page Title :", title);

        Assert.assertTrue(title.contains("Automation"),"Home page title validation failed");

        logger.info("Home Page Title Validation Successful");

        logger.info("===== Home Page Title Test Completed =====");
    }

    /**
     * Validates Signup/Login link
     * visibility on Home Page.
     */
    @Test
    public void verifySignupLoginLinkDisplayed() {

        logger.info( "===== Starting Signup/Login Link Validation Test =====");

        HomePage homePage = new HomePage( DriverFactory.getDriver());

        Assert.assertTrue( homePage.isSignupLoginDisplayed(),"Signup/Login link is not displayed");

        logger.info("Signup/Login link displayed successfully");

        logger.info("===== Signup/Login Validation Test Completed =====");
    }
}
